---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.intro {
				margin-bottom: 3rem;
			}
			.links {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
				gap: 1rem;
			}
			.links a {
				display: block;
				padding: 1.25rem;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 12px;
				color: rgb(var(--black));
				text-decoration: none;
				box-shadow: 0 2px 8px rgba(var(--gray), 12%);
			}
			.links a:hover {
				border-color: var(--accent);
				color: var(--accent);
			}
			.links strong {
				display: block;
				margin-bottom: 0.25rem;
			}
			.links span {
				color: rgb(var(--gray));
				font-size: 0.9em;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="intro">
				<h1>{SITE_TITLE}</h1>
				<p>{SITE_DESCRIPTION}</p>
			</section>
			<nav class="links" aria-label="Explore the collection">
				<a href={`${base}/blog`}>
					<strong>Blog</strong>
					<span>Read notes and updates.</span>
				</a>
				<a href={`${base}/papers`}>
					<strong>Papers</strong>
					<span>Browse research and coursework.</span>
				</a>
				<a href={`${base}/about`}>
					<strong>About</strong>
					<span>Learn more about Emily.</span>
				</a>
			</nav>
		</main>
		<Footer />
	</body>
</html>
