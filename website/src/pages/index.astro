---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { papers } from '../data/papers';
import { titleFromId } from '../utils/content';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const projects = await getCollection('projects');
const reviews = await getCollection('reviews');
const writing = await getCollection('writing');
const summaries = await getCollection('summaries');
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const itemCount =
	posts.length + projects.length + reviews.length + writing.length + summaries.length + papers.length + 1;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 1060px;
				padding-top: clamp(5rem, 10vw, 8rem);
			}
			.hero {
				position: relative;
				max-width: 900px;
				margin: 0 auto clamp(5rem, 9vw, 8rem);
				text-align: center;
			}
			.status {
				display: inline-flex;
				align-items: center;
				gap: 0.55rem;
				margin-bottom: 1.7rem;
				padding: 0.42rem 0.85rem;
				border: 1px solid rgba(185, 167, 255, 22%);
				border-radius: 999px;
				background: rgba(185, 167, 255, 6%);
				color: rgb(var(--gray));
				font-size: 0.72rem;
				letter-spacing: 0.08em;
				text-transform: uppercase;
			}
			.status::before {
				width: 0.42rem;
				height: 0.42rem;
				border-radius: 50%;
				background: var(--gold);
				box-shadow: 0 0 12px rgba(227, 195, 109, 0.65);
				content: '';
			}
			.hero h1 {
				margin-bottom: 1.4rem;
				font-size: clamp(3.1rem, 8vw, 6.2rem);
				line-height: 0.98;
			}
			.hero h1 em {
				background: linear-gradient(100deg, var(--accent) 15%, var(--gold-bright) 85%);
				background-clip: text;
				color: transparent;
				font-weight: 400;
			}
			.hero-description {
				max-width: 700px;
				margin: 0 auto 2.6rem;
				color: rgb(var(--gray));
				font-size: clamp(1rem, 2.2vw, 1.2rem);
			}
			.metrics {
				display: flex;
				justify-content: center;
				gap: clamp(2.5rem, 8vw, 6rem);
				margin: 0;
			}
			.metric {
				min-width: 6rem;
			}
			.metric strong {
				display: block;
				color: rgb(var(--black));
				font-family: Georgia, 'Times New Roman', serif;
				font-size: 2rem;
				font-weight: 500;
				line-height: 1;
			}
			.metric span {
				display: block;
				margin-top: 0.45rem;
				color: rgb(var(--gray));
				font-size: 0.66rem;
				letter-spacing: 0.12em;
				text-transform: uppercase;
			}
			.library-header {
				display: grid;
				grid-template-columns: 1fr minmax(260px, 0.65fr);
				align-items: end;
				margin-bottom: 1.7rem;
				gap: 2rem;
			}
			.kicker {
				margin: 0 0 0.65rem;
				color: var(--gold);
				font-size: 0.7rem;
				font-weight: 700;
				letter-spacing: 0.14em;
				text-transform: uppercase;
			}
			.library-header h2 {
				margin: 0;
			}
			.library-header > p {
				margin: 0;
				color: rgb(var(--gray));
				font-size: 0.92rem;
			}
			.explorer {
				--panel-text: #f4f1ff;
				--panel-muted: #aaa5c0;
				--panel-line: rgba(185, 167, 255, 0.18);
				position: relative;
				padding: clamp(1.25rem, 4vw, 2.6rem);
				border: 1px solid var(--panel-line);
				border-radius: 18px;
				background:
					linear-gradient(135deg, rgba(185, 167, 255, 7%), transparent 38%),
					linear-gradient(180deg, rgba(22, 23, 43, 96%), rgba(13, 15, 28, 98%));
				color: var(--panel-text);
				box-shadow: var(--box-shadow);
				overflow: hidden;
			}
			.explorer::before {
				position: absolute;
				top: 0;
				right: 12%;
				left: 12%;
				height: 1px;
				background: linear-gradient(90deg, transparent, var(--accent), var(--gold), transparent);
				content: '';
			}
			.explorer-heading {
				display: flex;
				align-items: center;
				justify-content: space-between;
				margin-bottom: 1.35rem;
				padding-bottom: 1.15rem;
				border-bottom: 1px solid var(--panel-line);
				gap: 1rem;
			}
			.collection-name {
				display: flex;
				align-items: center;
				gap: 0.75rem;
				margin: 0;
				color: var(--panel-text);
				font-family: var(--font-body);
				font-size: 0.92rem;
				font-weight: 700;
				letter-spacing: 0.08em;
				text-transform: uppercase;
			}
			.collection-mark {
				position: relative;
				width: 1.75rem;
				height: 1.75rem;
				flex: none;
				border: 1px solid var(--gold);
				border-radius: 50%;
			}
			.collection-mark::before,
			.collection-mark::after {
				position: absolute;
				inset: 50% auto auto 50%;
				width: 2.15rem;
				height: 0.7rem;
				border: 1px solid rgba(185, 167, 255, 55%);
				border-radius: 50%;
				content: '';
				transform: translate(-50%, -50%) rotate(32deg);
			}
			.collection-mark::after {
				transform: translate(-50%, -50%) rotate(-32deg);
			}
			.item-count {
				flex: none;
				padding: 0.3rem 0.65rem;
				border: 1px solid rgba(227, 195, 109, 18%);
				border-radius: 999px;
				background: rgba(227, 195, 109, 6%);
				color: var(--gold-bright);
				font-size: 0.65rem;
				letter-spacing: 0.1em;
				text-transform: uppercase;
			}
			.tree,
			.children {
				display: grid;
				gap: 0.28rem;
			}
			.children {
				margin: 0.25rem 0 0.25rem 0.8rem;
				padding-left: 1.3rem;
				border-left: 1px solid var(--panel-line);
			}
			details {
				min-width: 0;
			}
			summary,
			.file {
				display: flex;
				align-items: center;
				min-width: 0;
				padding: 0.62rem 0.7rem;
				border: 1px solid transparent;
				border-radius: 8px;
				color: var(--panel-text);
				font-weight: 700;
				line-height: 1.25;
				gap: 0.75rem;
			}
			summary {
				cursor: pointer;
				list-style: none;
			}
			summary::-webkit-details-marker {
				display: none;
			}
			summary:hover,
			.file:hover {
				border-color: rgba(185, 167, 255, 16%);
				background: rgba(185, 167, 255, 6%);
			}
			.chevron {
				width: 0.52rem;
				height: 0.52rem;
				flex: none;
				border-right: 2px solid var(--accent);
				border-bottom: 2px solid var(--accent);
				transform: rotate(-45deg);
				transition: transform 160ms ease;
			}
			details[open] > summary .chevron {
				transform: rotate(45deg) translate(-2px, -2px);
			}
			.folder-icon {
				position: relative;
				width: 1.15rem;
				height: 0.8rem;
				flex: none;
				border: 1px solid var(--gold);
				border-radius: 2px;
			}
			.folder-icon::before {
				position: absolute;
				top: -0.36rem;
				left: -1px;
				width: 0.48rem;
				height: 0.3rem;
				border: 1px solid var(--gold);
				border-bottom: 0;
				border-radius: 2px 2px 0 0;
				content: '';
			}
			.file {
				color: rgb(var(--gray-dark));
				text-decoration: none;
			}
			.file-icon {
				position: relative;
				width: 0.95rem;
				height: 1.2rem;
				flex: none;
				border: 1px solid var(--accent);
				border-radius: 2px;
			}
			.file-icon::after {
				position: absolute;
				right: -1px;
				bottom: 0.25rem;
				width: 0.42rem;
				border-top: 1px solid var(--accent);
				border-bottom: 1px solid var(--accent);
				content: '';
			}
			.file-name {
				min-width: 0;
				overflow-wrap: anywhere;
			}
			.badge {
				margin-left: auto;
				padding: 0.16rem 0.44rem;
				border: 1px solid rgba(227, 195, 109, 20%);
				border-radius: 999px;
				background: rgba(227, 195, 109, 7%);
				color: var(--gold-bright);
				font-size: 0.58rem;
				font-weight: 800;
				letter-spacing: 0.1em;
			}
			.empty {
				margin: 0.1rem 0 0.45rem 2.8rem;
				color: var(--panel-muted);
				font-size: 0.78rem;
				font-style: italic;
			}
			.folder-count {
				margin-left: auto;
				color: var(--panel-muted);
				font-size: 0.7rem;
				font-weight: 400;
			}
			@media (max-width: 700px) {
				.hero {
					margin-bottom: 4.5rem;
				}
				.metrics {
					gap: 1.7rem;
				}
				.metric {
					min-width: 0;
				}
				.library-header {
					grid-template-columns: 1fr;
					gap: 0.7rem;
				}
				.explorer-heading {
					align-items: flex-start;
					flex-direction: column;
				}
				.children {
					margin-left: 0.25rem;
					padding-left: 0.65rem;
				}
				summary,
				.file {
					padding-right: 0.35rem;
					padding-left: 0.35rem;
					gap: 0.55rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<div class="status">Open knowledge collection</div>
				<h1>A space for the <em>future of food</em></h1>
				<p class="hero-description">{SITE_DESCRIPTION}</p>
				<div class="metrics" aria-label="Collection overview">
					<div class="metric">
						<strong>{itemCount}</strong>
						<span>Files live</span>
					</div>
					<div class="metric">
						<strong>6</strong>
						<span>Library sections</span>
					</div>
					<div class="metric">
						<strong>100%</strong>
						<span>Open access</span>
					</div>
				</div>
			</section>

			<section aria-labelledby="library-heading">
				<div class="library-header">
					<div>
						<p class="kicker">Browse the archive</p>
						<h2 id="library-heading">The collection</h2>
					</div>
					<p>
						Explore notes, projects, reviews, and longer papers through the same folder structure
						used in the source library.
					</p>
				</div>

				<div class="explorer">
					<div class="explorer-heading">
						<h3 class="collection-name">
							<span class="collection-mark" aria-hidden="true"></span>
							ALT PROTEIN COLLECTION
						</h3>
						<span class="item-count">{itemCount} files</span>
					</div>

					<nav class="tree" aria-label="Content folder">
						<details open>
							<summary>
								<span class="chevron" aria-hidden="true"></span>
								<span class="folder-icon" aria-hidden="true"></span>
								<span>content</span>
							</summary>
							<div class="children">
								<details open>
									<summary>
										<span class="chevron" aria-hidden="true"></span>
										<span class="folder-icon" aria-hidden="true"></span>
										<span>blog</span>
										<span class="folder-count">{posts.length}</span>
									</summary>
									<div class="children">
										{
											posts.map((post) => (
												<a class="file" href={`${base}/blog/${post.id}/`}>
													<span class="file-icon" aria-hidden="true"></span>
													<span class="file-name">{post.data.title}</span>
													<span class="badge">MD</span>
												</a>
											))
										}
									</div>
								</details>

								<details>
									<summary>
										<span class="chevron" aria-hidden="true"></span>
										<span class="folder-icon" aria-hidden="true"></span>
										<span>projects</span>
										<span class="folder-count">{projects.length}</span>
									</summary>
									{
										projects.length ? (
											<div class="children">
												{projects.map((project) => (
													<a class="file" href={`${base}/projects/${project.id}/`}>
														<span class="file-icon" aria-hidden="true"></span>
														<span class="file-name">
															{project.data.title ?? titleFromId(project.id)}
														</span>
														<span class="badge">MD</span>
													</a>
												))}
											</div>
										) : (
											<p class="empty">Oops! This page is still under construction.</p>
										)
									}
								</details>

								<details>
									<summary>
										<span class="chevron" aria-hidden="true"></span>
										<span class="folder-icon" aria-hidden="true"></span>
										<span>reviews</span>
										<span class="folder-count">{reviews.length}</span>
									</summary>
									{
										reviews.length ? (
											<div class="children">
												{reviews.map((review) => (
													<a class="file" href={`${base}/reviews/${review.id}/`}>
														<span class="file-icon" aria-hidden="true"></span>
														<span class="file-name">{review.data.title ?? titleFromId(review.id)}</span>
														<span class="badge">MD</span>
													</a>
												))}
											</div>
										) : (
											<p class="empty">Oops! This page is still under construction.</p>
										)
									}
								</details>

								<details>
									<summary>
										<span class="chevron" aria-hidden="true"></span>
										<span class="folder-icon" aria-hidden="true"></span>
										<span>food writing</span>
										<span class="folder-count">{writing.length}</span>
									</summary>
									{
										writing.length ? (
											<div class="children">
												{writing.map((entry) => (
													<a class="file" href={`${base}/writing/${entry.id}/`}>
														<span class="file-icon" aria-hidden="true"></span>
														<span class="file-name">{entry.data.title ?? titleFromId(entry.id)}</span>
														<span class="badge">MD</span>
													</a>
												))}
											</div>
										) : (
											<p class="empty">Oops! This page is still under construction.</p>
										)
									}
								</details>

								<details open>
									<summary>
										<span class="chevron" aria-hidden="true"></span>
										<span class="folder-icon" aria-hidden="true"></span>
										<span>summaries</span>
										<span class="folder-count">{summaries.length + papers.length}</span>
									</summary>
									<div class="children">
										{
											summaries.map((summary) => (
												<a class="file" href={`${base}/papers/${summary.id}/`}>
													<span class="file-icon" aria-hidden="true"></span>
													<span class="file-name">
														{summary.data.title ?? titleFromId(summary.id)}
													</span>
													<span class="badge">MD</span>
												</a>
											))
										}
										{
											papers.map((paper) => (
												<a class="file" href={paper.url} target="_blank">
													<span class="file-icon" aria-hidden="true"></span>
													<span class="file-name">{paper.title}</span>
													<span class="badge">PDF</span>
												</a>
											))
										}
									</div>
								</details>

								<a class="file" href={`${base}/about`}>
									<span class="file-icon" aria-hidden="true"></span>
									<span class="file-name">about</span>
									<span class="badge">MD</span>
								</a>
							</div>
						</details>
					</nav>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
