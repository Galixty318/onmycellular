---
import { getCollection, render } from 'astro:content';
import BaseHead from '../../../../components/BaseHead.astro';
import Footer from '../../../../components/Footer.astro';
import Header from '../../../../components/Header.astro';
import '../../../../styles/overview.css';

export async function getStaticPaths() {
	const steps = await getCollection('overviewSteps');
	return steps.map((step) => ({ params: { step: step.data.slug }, props: { step } }));
}

const { step } = Astro.props;
const methods = (await getCollection('overviewMethods'))
	.filter((method) => method.data.step === step.data.slug)
	.sort((a, b) => a.data.order - b.data.order);
const { Content } = await render(step);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const projectHref = `${base}/projects/the-overview-project/`;
const methodHref = (substep: string, slug: string) => `${projectHref}${step.data.slug}/${substep}/${slug}/`;
---

<!doctype html>
<html lang="en">
	<head><BaseHead title={`${step.data.title} | The Overview Project`} description={step.data.description} /></head>
	<body>
		<Header />
		<main class="overview-main">
			<div class="overview-crumbs"><a href={projectHref}>The Overview Project</a><span>/</span><span>{step.data.title}</span></div>
			<header class="step-head">
				<p class="step-number">Step {String(step.data.order).padStart(2, '0')} of 06</p>
				<h1>{step.data.title}</h1>
				<div class="step-overview"><p class="overview-label">Step overview</p><Content /></div>
			</header>
			<div class="substeps">
				{step.data.substeps.sort((a, b) => a.order - b.order).map((substep) => {
					const substepMethods = methods.filter((method) => method.data.substep === substep.slug);
					return (
						<section class="substep-section">
							<header class="substep-header">
								<div><p class="substep-number">Sub-step {String(substep.order).padStart(2, '0')}</p><h2>{substep.title}</h2></div>
								<p>{substep.description}</p>
							</header>
							<div class="method-cards">
								{substepMethods.map((method, index) => (
									<a class="method-card" href={methodHref(substep.slug, method.data.slug)}>
										<span class="method-tag">Method {String(index + 1).padStart(2, '0')}</span>
										<h3>{method.data.title}</h3>
										<p>{method.data.description}</p>
										<span class="method-link">Read the in-depth page</span>
									</a>
								))}
							</div>
						</section>
					);
				})}
			</div>
		</main>
		<Footer />
	</body>
</html>
