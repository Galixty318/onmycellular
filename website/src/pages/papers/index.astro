---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { getCollection } from 'astro:content';
import { papers } from '../../data/papers';
import { titleFromId } from '../../utils/content';

const summaries = await getCollection('summaries');
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title="Summaries | Emily's Alt Protein Collection"
			description="Research summaries and coursework on alternative proteins and food systems."
		/>
		<style>
			.paper-list {
				list-style: none;
				padding: 0;
			}
			.paper-list li {
				padding: 1.25rem 0;
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			.paper-list h2 {
				margin-bottom: 0.25rem;
				font-size: 1.4em;
			}
			.paper-list p {
				margin: 0 0 0.75rem;
			}
			.paper-type {
				display: inline-block;
				margin-bottom: 0.6rem;
				color: var(--gold);
				font-size: 0.7rem;
				font-weight: 700;
				letter-spacing: 0.12em;
				text-transform: uppercase;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1>Summaries</h1>
			<ul class="paper-list">
				{
					summaries.map((summary) => (
						<li>
							<span class="paper-type">Markdown</span>
							<h2>{summary.data.title ?? titleFromId(summary.id)}</h2>
							{summary.data.description && <p>{summary.data.description}</p>}
							<a href={`${base}/papers/${summary.id}/`}>Read summary</a>
						</li>
					))
				}
				{
					papers.map((paper) => (
						<li>
							<span class="paper-type">PDF</span>
							<h2>{paper.title}</h2>
							<p>{paper.description}</p>
							<a href={paper.url} target="_blank">Read PDF</a>
						</li>
					))
				}
			</ul>
		</main>
		<Footer />
	</body>
</html>
