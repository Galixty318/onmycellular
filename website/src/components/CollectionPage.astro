---
import BaseHead from './BaseHead.astro';
import Footer from './Footer.astro';
import FormattedDate from './FormattedDate.astro';
import Header from './Header.astro';
import { titleFromId } from '../utils/content';

interface Entry {
	id: string;
	data: {
		title?: string;
		description?: string;
		pubDate?: Date;
	};
}

interface Props {
	title: string;
	description: string;
	path: string;
	entries: Entry[];
}

const { title, description, path, entries } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`${title} | Emily's Alt Protein Collection`} description={description} />
		<style>
			main {
				width: 960px;
			}
			.page-header {
				max-width: 720px;
				margin-bottom: 3rem;
			}
			.kicker {
				margin: 0 0 0.7rem;
				color: var(--gold);
				font-size: 0.7rem;
				font-weight: 700;
				letter-spacing: 0.14em;
				text-transform: uppercase;
			}
			.page-header p:last-child {
				color: rgb(var(--gray));
			}
			.entry-list {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
				margin: 0;
				padding: 0;
				gap: 1rem;
				list-style: none;
			}
			.entry-card {
				display: flex;
				min-height: 190px;
				padding: 1.4rem;
				border: 1px solid var(--line);
				border-radius: 14px;
				background: rgba(var(--surface-raised), 0.7);
				color: rgb(var(--gray-dark));
				flex-direction: column;
				text-decoration: none;
				transition:
					border-color 160ms ease,
					box-shadow 160ms ease,
					transform 160ms ease;
			}
			.entry-card:hover {
				border-color: rgba(227, 195, 109, 0.5);
				color: rgb(var(--gray-dark));
				box-shadow: 0 0 24px rgba(185, 167, 255, 0.22), 0 0 28px rgba(227, 195, 109, 0.12);
				transform: translateY(-2px);
			}
			.entry-card:hover h2 {
				background-image: var(--glow-gradient);
				background-clip: text;
				-webkit-background-clip: text;
				color: transparent;
				-webkit-text-fill-color: transparent;
				filter: drop-shadow(0 0 9px rgba(185, 167, 255, 0.45));
			}
			.entry-card h2 {
				font-size: 1.65rem;
			}
			.entry-card p {
				color: rgb(var(--gray));
				font-size: 0.9rem;
			}
			.entry-meta {
				margin-top: auto;
				color: var(--gold);
				font-size: 0.7rem;
				letter-spacing: 0.08em;
				text-transform: uppercase;
			}
			.empty {
				padding: 2rem;
				border: 1px dashed var(--line);
				border-radius: 14px;
				color: rgb(var(--gray));
				text-align: center;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<header class="page-header">
				<p class="kicker">Content library</p>
				<h1>{title}</h1>
				<p>{description}</p>
			</header>
			{
				entries.length ? (
					<ul class="entry-list">
						{entries.map((entry) => (
							<li>
								<a class="entry-card" href={`${base}/${path}/${entry.id}/`}>
									<h2>{entry.data.title ?? titleFromId(entry.id)}</h2>
									{entry.data.description && <p>{entry.data.description}</p>}
									<span class="entry-meta">
										{entry.data.pubDate ? <FormattedDate date={entry.data.pubDate} /> : 'Markdown'}
									</span>
								</a>
							</li>
						))}
					</ul>
				) : (
					<p class="empty">Oops! This page is still under construction.</p>
				)
			}
		</main>
		<Footer />
	</body>
</html>
