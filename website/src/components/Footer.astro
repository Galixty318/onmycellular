---
const today = new Date();
---

<footer>
	<div class="footer-inner">
		<span class="footer-mark" aria-hidden="true"></span>
		<span>Open notes on alternative proteins and bioprocess engineering.</span>
		<span>&copy; {today.getFullYear()} Emily Li</span>
	</div>
</footer>
<style>
	footer {
		padding: 2rem 1rem 3rem;
		border-top: 1px solid var(--line);
		color: rgb(var(--gray));
		font-size: 0.8rem;
	}
	.footer-inner {
		display: flex;
		align-items: center;
		width: 1180px;
		max-width: 100%;
		margin: auto;
		gap: 0.75rem;
	}
	.footer-inner span:last-child {
		margin-left: auto;
	}
	.footer-mark {
		width: 0.45rem;
		height: 0.45rem;
		flex: none;
		border-radius: 50%;
		background: var(--gold);
		box-shadow: 0 0 14px rgba(250, 178, 92, 0.55);
	}
	@media (max-width: 680px) {
		.footer-inner {
			align-items: flex-start;
			flex-direction: column;
		}
		.footer-inner span:last-child {
			margin-left: 0;
		}
	}
</style>
