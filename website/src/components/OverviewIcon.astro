---
interface Props {
	name: 'source' | 'proliferation' | 'differentiation' | 'formation' | 'harvest' | 'processing';
}

const { name } = Astro.props;
---

<svg class="stage-icon" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
	{name === 'source' && <><ellipse cx="24" cy="29" rx="18" ry="9" /><path d="M6 25v4m36-4v4M9 23c5-5 25-5 30 0" /><circle cx="18" cy="27" r="2.5" /><circle cx="28" cy="24" r="3.5" /></>}
	{name === 'proliferation' && <><circle cx="17" cy="24" r="9" /><circle cx="31" cy="24" r="9" /><path d="M24 9v30M19 6h10M19 42h10" /></>}
	{name === 'differentiation' && <><path d="M24 39V21M24 27 12 15M24 27l12-12" /><circle cx="24" cy="40" r="4" /><circle cx="11" cy="14" r="5" /><circle cx="37" cy="14" r="5" /></>}
	{name === 'formation' && <><path d="m8 17 16-8 16 8-16 8-16-8Z" /><path d="m8 25 16 8 16-8M8 33l16 8 16-8" /></>}
	{name === 'harvest' && <><path d="M9 22h30l-4 18H13L9 22Z" /><path d="M15 22c0-9 3-14 9-14s9 5 9 14M11 27h26M12 33h24M18 23l1 17M30 23l-1 17" /><circle cx="15" cy="21" r="2.2" /><circle cx="24" cy="15" r="2.6" /><circle cx="35" cy="8.5" r="1.8" /></>}
	{name === 'processing' && <><path d="M7 34h34M11 34V20l8 5v-5l8 5v-5l10 6v8M16 39h16" /><circle cx="14" cy="14" r="3" /><circle cx="24" cy="11" r="4" /></>}
</svg>
