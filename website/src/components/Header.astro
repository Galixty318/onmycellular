---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';

const base = `${import.meta.env.BASE_URL.replace(/\/$/, '')}/`;
---

<header class="site-header">
	<nav class="site-nav">
		<a class="brand" href={base} aria-label={SITE_TITLE}>
			<span>{SITE_TITLE}</span>
		</a>
		<div class="internal-links">
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/projects">Projects</HeaderLink>
			<HeaderLink href="/reviews">Reviews</HeaderLink>
			<HeaderLink href="/writing">Food Writing</HeaderLink>
			<HeaderLink href="/papers">Summaries</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>
	</nav>
</header>
<style>
	.site-header {
		position: sticky;
		z-index: 10;
		top: 0;
		border-bottom: 1px solid rgba(185, 167, 255, 14%);
		background: rgba(23, 20, 42, 86%);
		backdrop-filter: blur(16px);
	}
	.site-nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		width: 1180px;
		max-width: calc(100% - 2rem);
		min-height: 72px;
		margin: auto;
		gap: 2rem;
	}
	.brand {
		display: flex;
		align-items: center;
		gap: 0.7rem;
		color: rgb(var(--black));
		font-family: Georgia, 'Times New Roman', serif;
		font-size: 1rem;
		text-decoration: none;
	}
	.brand:hover {
		color: var(--gold-bright);
		text-shadow: var(--glow-shadow);
	}
	.internal-links {
		display: flex;
		align-items: center;
		gap: 1.6rem;
	}
	.internal-links :global(a) {
		position: relative;
		padding: 1.5rem 0;
		color: rgb(var(--gray));
		font-size: 0.84rem;
		letter-spacing: 0.04em;
		text-decoration: none;
		transition:
			color 160ms ease,
			text-shadow 160ms ease;
	}
	.internal-links :global(a:hover),
	.internal-links :global(a.active) {
		color: var(--gold-bright);
		text-shadow: var(--glow-shadow);
	}
	.internal-links :global(a:hover) {
		background-image: var(--glow-gradient);
		background-clip: text;
		-webkit-background-clip: text;
		color: transparent;
		-webkit-text-fill-color: transparent;
	}
	.internal-links :global(a.active)::after {
		position: absolute;
		right: -0.3rem;
		bottom: -4px;
		left: -0.3rem;
		height: 9px;
		border-radius: 999px;
		background:
			radial-gradient(ellipse at center, rgba(243, 217, 134, 0.7) 0%, rgba(243, 217, 134, 0) 62%),
			linear-gradient(
				90deg,
				transparent 0%,
				rgba(185, 167, 255, 0.15) 14%,
				var(--accent-bright) 36%,
				var(--gold-bright) 64%,
				rgba(227, 195, 109, 0.15) 86%,
				transparent 100%
			);
		filter: blur(1.5px);
		content: '';
		pointer-events: none;
	}
	@media (max-width: 1050px) {
		.site-nav {
			align-items: flex-start;
			flex-direction: column;
			min-height: auto;
			padding: 1rem 0 0;
			gap: 0.35rem;
		}
		.brand {
			font-size: 0.95rem;
			line-height: 1.25;
		}
		.internal-links {
			display: grid;
			grid-template-columns: repeat(3, minmax(0, 1fr));
			width: 100%;
			gap: 0 1rem;
			overflow: visible;
		}
		.internal-links :global(a) {
			padding: 0.75rem 0;
			white-space: normal;
		}
	}
	@media (max-width: 420px) {
		.internal-links {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}
</style>
