---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';

const base = `${import.meta.env.BASE_URL.replace(/\/$/, '')}/`;
---

<header class="site-header">
	<nav class="site-nav">
		<a class="brand" href={base} aria-label={SITE_TITLE}>
			<span class="brand-mark" aria-hidden="true"><span></span></span>
			<span>{SITE_TITLE}</span>
		</a>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/projects">Projects</HeaderLink>
			<HeaderLink href="/reviews">Reviews</HeaderLink>
			<HeaderLink href="/papers">Papers</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>
	</nav>
</header>
<style>
	.site-header {
		position: sticky;
		z-index: 10;
		top: 0;
		border-bottom: 1px solid rgba(185, 167, 255, 14%);
		background: rgba(8, 10, 20, 86%);
		backdrop-filter: blur(16px);
	}
	.site-nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		width: 1180px;
		max-width: calc(100% - 2rem);
		min-height: 72px;
		margin: auto;
		gap: 2rem;
	}
	.brand {
		display: flex;
		align-items: center;
		gap: 0.7rem;
		color: rgb(var(--black));
		font-family: Georgia, 'Times New Roman', serif;
		font-size: 1rem;
		text-decoration: none;
	}
	.brand:hover {
		color: var(--gold-bright);
	}
	.brand-mark {
		position: relative;
		width: 1.55rem;
		height: 1.55rem;
		flex: none;
		border: 1px solid var(--gold);
		border-radius: 50%;
	}
	.brand-mark::before,
	.brand-mark::after {
		position: absolute;
		inset: 50% auto auto 50%;
		width: 2rem;
		height: 0.6rem;
		border: 1px solid rgba(185, 167, 255, 65%);
		border-radius: 50%;
		content: '';
		transform: translate(-50%, -50%) rotate(35deg);
	}
	.brand-mark::after {
		transform: translate(-50%, -50%) rotate(-35deg);
	}
	.brand-mark span {
		position: absolute;
		z-index: 1;
		inset: 50% auto auto 50%;
		width: 0.3rem;
		height: 0.3rem;
		border-radius: 50%;
		background: var(--gold-bright);
		transform: translate(-50%, -50%);
	}
	.internal-links {
		display: flex;
		align-items: center;
		gap: 1.6rem;
	}
	.internal-links :global(a) {
		position: relative;
		padding: 1.5rem 0;
		color: rgb(var(--gray));
		font-size: 0.84rem;
		letter-spacing: 0.04em;
		text-decoration: none;
	}
	.internal-links :global(a:hover),
	.internal-links :global(a.active) {
		color: rgb(var(--black));
	}
	.internal-links :global(a.active)::after {
		position: absolute;
		right: 0;
		bottom: -1px;
		left: 0;
		height: 2px;
		background: linear-gradient(90deg, var(--accent), var(--gold));
		content: '';
	}
	@media (max-width: 720px) {
		.site-nav {
			align-items: flex-start;
			flex-direction: column;
			min-height: auto;
			padding: 1rem 0 0;
			gap: 0.35rem;
		}
		.brand {
			font-size: 0.95rem;
		}
		.internal-links {
			width: 100%;
			gap: 1.2rem;
			overflow-x: auto;
		}
		.internal-links :global(a) {
			padding: 0.75rem 0;
		}
	}
</style>
